# Skopiuj do .env i uzupełnij wartości przed uruchomieniem.
# NIE commituj .env do repozytorium.

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=zmien_na_silne_haslo_root
MYSQL_DATABASE=grant_docs
MYSQL_USER=grant_docs
MYSQL_PASSWORD=zmien_na_silne_haslo

# ── Aplikacja ─────────────────────────────────────────────────────────────────
# Wygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=wygeneruj_losowy_klucz_min_32_znaki

# Port na hoście (domyślnie 8000)
APP_PORT=8000

# ── Opcjonalne ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
COMPARISON_TIMEOUT_MINUTES=60
GEMINI_SLEEP_SECONDS=1.0
GEMINI_BATCH_SECTIONS=20
