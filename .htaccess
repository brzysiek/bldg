TimeOut 600

<IfModule mod_reqtimeout.c>
    RequestReadTimeout header=20,minrate=500 body=600,minrate=500
</IfModule>

# Keep 2 warm workers — consistent with Passengerfile.json min_instances.
# .htaccess overrides Passengerfile.json, so this is the authoritative value.
PassengerMinInstances 2

# High threshold — workers serve tens of thousands of requests before recycling.
# Low values (e.g. 500) caused SIGTERM mid-task when background Gemini threads
# were running, because aggressive polling during bulk operations hit the limit fast.
PassengerMaxRequests 10000
